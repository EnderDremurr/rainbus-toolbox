<UserControl
    d:DesignHeight="800"
    d:DesignWidth="1200"
    mc:Ignorable="d"
    x:Class="RainbusToolbox.Views.TranslationTab"
    x:DataType="vm:TranslationTabViewModel"
    x:Name="TopLevelControl"
    xmlns="https://github.com/avaloniaui"
    xmlns:conv="clr-namespace:RainbusToolbox.Utilities.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:RainbusToolbox.Models"
    xmlns:vm="clr-namespace:RainbusToolbox.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <conv:InverseBoolConverter x:Key="InverseBoolConverter" />
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*">
        <!--  File Selection Header  -->
        <Border
            Background="Transparent"
            BorderBrush="Transparent"
            BorderThickness="0,0,0,1"
            Grid.Row="0"
            Padding="20,15">

            <Grid>
                <!--  Left: Select File Button  -->
                <Button
                    Command="{Binding SelectFileCommand}"
                    Content="Выбрать файл"
                    Height="60"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Width="280" />

                <!--  Center: File type info  -->
                <StackPanel
                    HorizontalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="10"
                    VerticalAlignment="Center">
                    <TextBlock
                        Foreground="#CCCCCC"
                        Text="Редактируемый файл:"
                        VerticalAlignment="Center" />
                    <TextBlock
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="{Binding FileName}"
                        VerticalAlignment="Center" />
                    <Border
                        Background="#0E639C"
                        CornerRadius="12"
                        IsVisible="{Binding IsFileLoaded}"
                        Padding="8,4"
                        VerticalAlignment="Center">
                        <TextBlock
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="{Binding FileType}" />
                    </Border>
                </StackPanel>

                <!--  Right: Save Buttons  -->
                <StackPanel
                    HorizontalAlignment="Right"
                    IsVisible="{Binding IsFileLoaded}"
                    Orientation="Horizontal"
                    Spacing="10"
                    VerticalAlignment="Center">
                    <Button
                        Command="{Binding SaveObjectFromCurrentEditorCommand}"
                        Content="Сохранить"
                        Height="60"
                        Width="280" />
                    <Button
                        Command="{Binding SaveObjectFromCurrentEditorAndClose}"
                        Content="Сохранить и закрыть"
                        Height="60"
                        Width="280" />
                </StackPanel>
            </Grid>
        </Border>

        <!--  Dynamic Editor Content  -->
        <ContentControl
            Content="{Binding CurrentEditor}"
            Grid.Row="1"
            IsVisible="{Binding IsFileLoaded}" />

        <!--  Welcome / Empty State  -->
        <Border Grid.Row="1" IsVisible="{Binding IsFileLoaded, Converter={StaticResource InverseBoolConverter}}">
            <TabControl
                ItemContainerTheme="{StaticResource GenericTabTheme}"
                ItemsSource="{Binding GroupedShortcuts}"
                Margin="0,30,0,0">
                <TabControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock
                            FontFamily="{StaticResource MikodacsFont}"
                            FontSize="22"
                            Foreground="White"
                            Text="{Binding Key}" />
                    </DataTemplate>
                </TabControl.ItemTemplate>
                <TabControl.ContentTemplate>
                    <DataTemplate>
                        <ItemsControl ItemsSource="{Binding}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:FileShortcut">
                                    <Button
                                        Command="{Binding OpenCommand}"
                                        CommandParameter="{Binding FullPath}"
                                        Content="{Binding Alias}"
                                        Height="75"
                                        Margin="10"
                                        Width="300" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DataTemplate>
                </TabControl.ContentTemplate>
            </TabControl>
        </Border>
    </Grid>
</UserControl>