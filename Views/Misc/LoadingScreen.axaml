<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="RainbusToolbox.Views.Misc.LoadingScreen"
    x:DataType="viewModels:LoadingScreenViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:RainbusToolbox.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border
        Background="#80000000"
        HorizontalAlignment="Stretch"
        IsHitTestVisible="{Binding IsLoading}"
        IsVisible="{Binding IsLoading}"
        VerticalAlignment="Stretch">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock
                Classes="header"
                FontSize="48"
                Foreground="White"
                Margin="0,0,0,10"
                Text="{Binding Text}" />
            <StackPanel Width="1184">
                <ProgressBar
                    IsIndeterminate="{Binding !IsDeterministic}"
                    Maximum="1"
                    Value="{Binding ProgressPercent}" />
                <Grid IsVisible="{Binding IsDeterministic}">
                    <TextBlock
                        Classes="header"
                        FontSize="56"
                        Foreground="White"
                        HorizontalAlignment="Left"
                        Margin="0,10,0,0">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0} / {1}">
                                <Binding Path="ProgressCompleted" />
                                <Binding Path="ProgressTotal" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <TextBlock
                        Classes="header"
                        FontSize="56"
                        Foreground="White"
                        HorizontalAlignment="Right"
                        Margin="0,10,0,0"
                        Text="{Binding ProgressPercent, StringFormat={}{0:P0}}" />
                </Grid>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>