<UserControl
    d:DesignHeight="800"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="RainbusToolbox.Views.StoryTranslationEditor"
    x:DataType="vm:StoryTranslationEditorViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:misc="clr-namespace:RainbusToolbox.Views.Misc"
    xmlns:vm="clr-namespace:RainbusToolbox.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid RowDefinitions="Auto,*,Auto,*,Auto">

        <!--  Reference Section  -->
        <Border
            Grid.Row="1"
            IsVisible="{Binding IsFileLoaded}"
            Margin="20,0,20,10">
            <Grid>
                <Image
                    Height="250"
                    HorizontalAlignment="Stretch"
                    Margin="240,0,0,0"
                    Source="avares://RainbusToolbox/Assets/StoryBG.png" />
                <Grid Margin="25,20,25,20">
                    <TextBlock
                        Classes="invisible"
                        FontSize="22"
                        HorizontalAlignment="Stretch"
                        Margin="430,60,300,40"
                        Text="{Binding ReferenceItem.Content}"
                        TextWrapping="Wrap"
                        VerticalAlignment="Stretch" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        Margin="0,0,0,15"
                        Text="{Binding ReferenceItem.Place}"
                        VerticalAlignment="Bottom" />
                    <Grid HorizontalAlignment="Left" VerticalAlignment="Top">
                        <Image
                            Height="225"
                            Margin="0,-40,0,0"
                            Source="avares://RainbusToolbox/Assets/StoryBGName.png"
                            Width="450" />
                        <Grid
                            HorizontalAlignment="Center"
                            Margin="0,15,0,15"
                            VerticalAlignment="Top">
                            <TextBlock
                                FontFamily="{StaticResource MikodacsFont}"
                                FontSize="28"
                                FontWeight="Bold"
                                HorizontalAlignment="Center"
                                Margin="35,-13,0,0"
                                MaxWidth="250"
                                Text="{Binding DisplayTitleReference}"
                                VerticalAlignment="Top">
                                <TextBlock.Effect>
                                    <DropShadowEffect
                                        BlurRadius="0"
                                        Color="Black"
                                        OffsetX="2"
                                        OffsetY="2"
                                        Opacity="0.8" />
                                </TextBlock.Effect>
                                <TextBlock.RenderTransform>
                                    <RotateTransform Angle="-6.9" />
                                </TextBlock.RenderTransform>
                            </TextBlock>
                            <TextBlock
                                FontFamily="{StaticResource MikodacsFont}"
                                FontSize="34"
                                HorizontalAlignment="Center"
                                Margin="130,55,0,0"
                                Text="{Binding DisplayTellerReference}"
                                VerticalAlignment="Top">
                                <TextBlock.Effect>
                                    <DropShadowEffect
                                        BlurRadius="0"
                                        Color="Black"
                                        OffsetX="2"
                                        OffsetY="2"
                                        Opacity="0.8" />
                                </TextBlock.Effect>
                                <TextBlock.RenderTransform>
                                    <RotateTransform Angle="-6.5" />
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <!--  Separator  -->
        <Border
            Background="Transparent"
            Grid.Row="2"
            Height="3"
            Margin="30,5,30,5" />

        <!--  Editor Section  -->
        <Border
            Grid.Row="3"
            IsVisible="{Binding IsFileLoaded}"
            Margin="20,10,20,15">
            <Grid>
                <Image
                    Height="250"
                    HorizontalAlignment="Stretch"
                    Margin="240,0,0,0"
                    Source="avares://RainbusToolbox/Assets/StoryBG.png" />
                <Grid Margin="20,10,20,10">
                    <TextBox
                        AcceptsReturn="True"
                        Background="Transparent"
                        BorderThickness="0"
                        Classes="invisible"
                        FontSize="22"
                        HorizontalAlignment="Stretch"
                        Margin="430,60,300,40"
                        Text="{Binding CurrentItem.Content, Mode=TwoWay}"
                        TextWrapping="Wrap"
                        VerticalAlignment="Stretch" />
                    <TextBox
                        Background="Transparent"
                        BorderThickness="0"
                        Classes="invisible"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,15"
                        Text="{Binding CurrentItem.Place, Mode=TwoWay}"
                        VerticalAlignment="Bottom" />
                    <Grid HorizontalAlignment="Left" VerticalAlignment="Top">
                        <Image
                            Height="225"
                            Margin="0,-40,0,0"
                            Source="avares://RainbusToolbox/Assets/StoryBGName.png"
                            Width="450" />
                        <Grid
                            HorizontalAlignment="Center"
                            Margin="0,15,0,15"
                            VerticalAlignment="Top">
                            <TextBox
                                Background="Transparent"
                                BorderThickness="0"
                                Classes="invisible"
                                FontFamily="{StaticResource MikodacsFont}"
                                FontSize="28"
                                FontWeight="Bold"
                                HorizontalAlignment="Center"
                                IsReadOnly="{Binding !CanEditTitle}"
                                Margin="35,-13,0,0"
                                MaxWidth="250"
                                Text="{Binding DisplayTitle, Mode=TwoWay}"
                                VerticalAlignment="Top">
                                <TextBox.Effect>
                                    <DropShadowEffect
                                        BlurRadius="0"
                                        Color="Black"
                                        OffsetX="2"
                                        OffsetY="2"
                                        Opacity="0.8" />
                                </TextBox.Effect>
                                <TextBox.RenderTransform>
                                    <RotateTransform Angle="-6.9" />
                                </TextBox.RenderTransform>
                            </TextBox>
                            <TextBox
                                Background="Transparent"
                                BorderThickness="0"
                                Classes="invisible"
                                FontFamily="{StaticResource MikodacsFont}"
                                FontSize="34"
                                HorizontalAlignment="Center"
                                IsReadOnly="{Binding !CanEditTeller}"
                                Margin="130,55,0,0"
                                Text="{Binding DisplayTeller, Mode=TwoWay}"
                                VerticalAlignment="Top">
                                <TextBox.Effect>
                                    <DropShadowEffect
                                        BlurRadius="0"
                                        Color="Black"
                                        OffsetX="2"
                                        OffsetY="2"
                                        Opacity="0.8" />
                                </TextBox.Effect>
                                <TextBox.RenderTransform>
                                    <RotateTransform Angle="-6.5" />
                                </TextBox.RenderTransform>
                            </TextBox>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <!--  Navigation  -->
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <misc:NavigationBar />
        </StackPanel>
    </Grid>
</UserControl>