<UserControl
    d:DesignHeight="800"
    d:DesignWidth="1200"
    mc:Ignorable="d"
    x:Class="RainbusToolbox.Views.PassiveTranslationEditor"
    x:DataType="viewModels:PassiveTranslationEditorViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:misc="clr-namespace:RainbusToolbox.Views.Misc"
    xmlns:viewModels="clr-namespace:RainbusToolbox.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid RowDefinitions="Auto,*,Auto">
        <!--  Main Content - Vertical Split  -->
        <Grid
            ColumnDefinitions="*,*"
            Grid.Row="1"
            IsVisible="{Binding IsFileLoaded}"
            Margin="20,0,20,15">

            <!--  Reference Section (Left)  -->
            <Border
                ClipToBounds="True"
                Grid.Column="0"
                Margin="0,0,10,0">
                <Panel>
                    <!--  Background Image  -->
                    <Image
                        HorizontalAlignment="Stretch"
                        Source="avares://RainbusToolbox/Assets/SkillBG.png"
                        Stretch="Uniform"
                        StretchDirection="Both"
                        VerticalAlignment="Stretch" />

                    <!--  Content Area  -->
                    <Border Margin="72,54,114,195">
                        <ScrollViewer>
                            <StackPanel Margin="15">
                                <!--  Passive Title  -->
                                <StackPanel Margin="0,10,0,0">
                                    <TextBox
                                        Background="Transparent"
                                        Classes="invisible"
                                        FontFamily="{StaticResource MikodacsFont}"
                                        FontSize="28"
                                        FontWeight="SemiBold"
                                        Foreground="White"
                                        Text="{Binding ReferenceItem.Name, Mode=TwoWay}"
                                        TextWrapping="Wrap" />
                                </StackPanel>

                                <!--  Passive Description  -->
                                <StackPanel Margin="0,10,0,10">
                                    <TextBox
                                        Background="Transparent"
                                        Classes="invisible"
                                        IsReadOnly="True"
                                        MinHeight="100"
                                        Text="{Binding ReferenceItem.Desc}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Panel>
            </Border>

            <!--  Editor Section (Right)  -->
            <Border
                ClipToBounds="True"
                Grid.Column="1"
                Margin="10,0,0,0">
                <Panel>
                    <!--  Background Image  -->
                    <Image
                        HorizontalAlignment="Stretch"
                        Source="avares://RainbusToolbox/Assets/SkillBG.png"
                        Stretch="Uniform"
                        StretchDirection="Both"
                        VerticalAlignment="Stretch" />

                    <!--  Content Area  -->
                    <Border Margin="72,54,114,195">
                        <ScrollViewer>
                            <StackPanel Margin="15">


                                <!--  Passive Title  -->
                                <StackPanel Margin="0,10,0,0">
                                    <TextBox
                                        Background="Transparent"
                                        Classes="invisible"
                                        FontFamily="{StaticResource MikodacsFont}"
                                        FontSize="28"
                                        FontWeight="SemiBold"
                                        Foreground="White"
                                        Text="{Binding CurrentItem.Name, Mode=TwoWay}"
                                        TextWrapping="Wrap" />
                                </StackPanel>

                                <!--  Passive Description  -->
                                <StackPanel Margin="0,10,0,10">
                                    <TextBox
                                        AcceptsReturn="True"
                                        Background="Transparent"
                                        Classes="invisible"
                                        MinHeight="100"
                                        Text="{Binding CurrentItem.Desc, Mode=TwoWay}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Panel>
            </Border>
        </Grid>

        <!--  Navigation Container  -->
        <StackPanel
            Grid.Row="2"
            HorizontalAlignment="Center"
            IsVisible="{Binding IsFileLoaded}"
            Margin="20,5,20,20"
            Orientation="Horizontal">

            <!--  Passive Navigation Section  -->
            <misc:NavigationBar />
        </StackPanel>
    </Grid>
</UserControl>