<Styles xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Design.PreviewWith>
        <Border Background="#222" Padding="20">
            <StackPanel Spacing="12">
                <Button
                    Content="Medium"
                    Height="48"
                    Width="160" />
                <Button
                    Content="Default"
                    Height="56"
                    Width="200" />
                <Button
                    Content="Large"
                    Height="64"
                    Width="240" />
                <Button
                    Content="Wide Button"
                    Height="56"
                    Width="320" />
                <Button
                    Content="Big Square"
                    Height="140"
                    Width="140" />
            </StackPanel>
        </Border>
    </Design.PreviewWith>

    <!--  Generic Button template  -->
    <Style Selector="Button">
        <Setter Property="Template">
            <ControlTemplate TargetType="Button">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="16" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="16" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                    </Grid.ColumnDefinitions>

                    <!--  Corners  -->
                    <Image
                        Grid.Column="0"
                        Grid.Row="0"
                        Name="TopLeft" />
                    <Image
                        Grid.Column="2"
                        Grid.Row="0"
                        Name="TopRight" />
                    <Image
                        Grid.Column="0"
                        Grid.Row="2"
                        Name="BottomLeft" />
                    <Image
                        Grid.Column="2"
                        Grid.Row="2"
                        Name="BottomRight" />

                    <!--  Edges  -->
                    <Image
                        Grid.Column="1"
                        Grid.Row="0"
                        Name="Top"
                        Stretch="Fill" />
                    <Image
                        Grid.Column="1"
                        Grid.Row="2"
                        Name="Bottom"
                        Stretch="Fill" />
                    <Image
                        Grid.Column="0"
                        Grid.Row="1"
                        Name="Left"
                        Stretch="Fill" />
                    <Image
                        Grid.Column="2"
                        Grid.Row="1"
                        Name="Right"
                        Stretch="Fill" />

                    <!--  Center  -->
                    <Image
                        Grid.Column="1"
                        Grid.Row="1"
                        Name="Center"
                        Stretch="Fill" />

                    <!--  Content on top  -->
                    <TextBlock
                        FontFamily="{StaticResource MikodacsFont}"
                        FontSize="22"
                        Foreground="White"
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        Grid.Row="0"
                        Grid.RowSpan="3"
                        HorizontalAlignment="Center"
                        Text="{TemplateBinding Content}"
                        TextWrapping="Wrap"
                        VerticalAlignment="Center" />
                </Grid>
            </ControlTemplate>
        </Setter>
    </Style>

    <!--  Idle state  -->
    <Style Selector="Button Image#TopLeft">
        <Setter Property="Source" Value="/Assets/MainButtonIdleTopLeft.png" />
    </Style>
    <Style Selector="Button Image#TopRight">
        <Setter Property="Source" Value="/Assets/MainButtonIdleTopRight.png" />
    </Style>
    <Style Selector="Button Image#BottomLeft">
        <Setter Property="Source" Value="/Assets/MainButtonIdleBottomLeft.png" />
    </Style>
    <Style Selector="Button Image#BottomRight">
        <Setter Property="Source" Value="/Assets/MainButtonIdleBottomRight.png" />
    </Style>
    <Style Selector="Button Image#Top">
        <Setter Property="Source" Value="/Assets/MainButtonIdleTop.png" />
    </Style>
    <Style Selector="Button Image#Bottom">
        <Setter Property="Source" Value="/Assets/MainButtonIdleBottom.png" />
    </Style>
    <Style Selector="Button Image#Left">
        <Setter Property="Source" Value="/Assets/MainButtonIdleLeft.png" />
    </Style>
    <Style Selector="Button Image#Right">
        <Setter Property="Source" Value="/Assets/MainButtonIdleRight.png" />
    </Style>
    <Style Selector="Button Image#Center">
        <Setter Property="Source" Value="/Assets/MainButtonIdleCenter.png" />
    </Style>

    <!--  Hovered state  -->
    <Style Selector="Button:pointerover Image#TopLeft">
        <Setter Property="Source" Value="/Assets/MainButtonHoverTopLeft.png" />
    </Style>
    <Style Selector="Button:pointerover Image#TopRight">
        <Setter Property="Source" Value="/Assets/MainButtonHoverTopRight.png" />
    </Style>
    <Style Selector="Button:pointerover Image#BottomLeft">
        <Setter Property="Source" Value="/Assets/MainButtonHoverBottomLeft.png" />
    </Style>
    <Style Selector="Button:pointerover Image#BottomRight">
        <Setter Property="Source" Value="/Assets/MainButtonHoverBottomRight.png" />
    </Style>
    <Style Selector="Button:pointerover Image#Top">
        <Setter Property="Source" Value="/Assets/MainButtonHoverTop.png" />
    </Style>
    <Style Selector="Button:pointerover Image#Bottom">
        <Setter Property="Source" Value="/Assets/MainButtonHoverBottom.png" />
    </Style>
    <Style Selector="Button:pointerover Image#Left">
        <Setter Property="Source" Value="/Assets/MainButtonHoverLeft.png" />
    </Style>
    <Style Selector="Button:pointerover Image#Right">
        <Setter Property="Source" Value="/Assets/MainButtonHoverRight.png" />
    </Style>
    <Style Selector="Button:pointerover Image#Center">
        <Setter Property="Source" Value="/Assets/MainButtonHoverCenter.png" />
    </Style>
</Styles>