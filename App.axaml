<Application
    RequestedThemeVariant="Default"
    x:Class="RainbusToolbox.App"
    xmlns="https://github.com/avaloniaui"
    xmlns:global1="clr-namespace:"
    xmlns:local="using:RainbusToolbox"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Resources>
        <!--  Converter instance for checkbox images  -->
        <local:CheckedToImageConverter x:Key="CheckedToImageConverter" />
        <!--  Custom font registration  -->
        <FontFamily x:Key="PretendardFont">avares://RainbusToolbox/Assets/Fonts/Pretendard.ttf#Pretendard</FontFamily>
        <FontFamily x:Key="MikodacsFont">avares://RainbusToolbox/Assets/Fonts/Mikodacs.ttf#Mikodacs Regular</FontFamily>
        <global1:TextBoxTextConverter x:Key="TextBoxTextConverter" />
        <DropShadowEffect
            BlurRadius="0"
            Color="Black"
            OffsetX="1"
            OffsetY="1"
            Opacity="1"
            x:Key="HardShadow" />
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />

        <StyleInclude Source="avares://RainbusToolbox/Styles/Typography.axaml" />
        <StyleInclude Source="avares://RainbusToolbox/Styles/Themes/DefaultButtonTheme.axaml" />
        <StyleInclude Source="avares://RainbusToolbox/Styles/Themes/GenericTabItemTheme.axaml" />
        <StyleInclude Source="avares://RainbusToolbox/Styles/Themes/TextBoxFramedTheme.axaml" />
        <StyleInclude Source="avares://RainbusToolbox/Styles/Themes/TextBoxInvisibleTheme.axaml" />
        <StyleInclude Source="avares://RainbusToolbox/Styles/Controls/Checkbox.axaml" />
        <StyleInclude Source="avares://RainbusToolbox/Styles/Controls/NavigationButtons.axaml" />
        <StyleInclude Source="avares://RainbusToolbox/Styles/Controls/NavigationTabs.axaml" />

        <Style Selector="Border.framed">
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="BorderBrush" Value="White" />
            <Setter Property="Background" Value="Transparent" />
        </Style>


    </Application.Styles>
</Application>